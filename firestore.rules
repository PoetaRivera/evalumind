rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /responses/{response} {
      // Nadie puede leer los datos de screening
      allow read: if false;

      // Solo permitir crear documentos con estructura validada
      allow create: if
        request.resource.data.keys().hasAll(['testId', 'sessionId', 'createdAt'])
        && request.resource.data.testId is string
        && request.resource.data.testId.size() > 0
        && request.resource.data.testId.size() < 100
        && request.resource.data.sessionId is string
        && request.resource.data.sessionId.size() > 0;

      // No permitir updates ni deletes desde el cliente
      allow update, delete: if false;
    }
  }
}
